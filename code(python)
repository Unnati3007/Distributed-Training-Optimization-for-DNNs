import os
import torch
import torch.nn as nn
import torch.distributed as dist
from torch.nn.parallel import DistributedDataParallel as DDP
from torch.cuda.amp import GradScaler, autocast

def setup_distributed_env(node_rank, world_size):
    """
    Initializes the distributed process group using the NCCL backend.
    Optimized for multi-GPU training clusters.
    """
    os.environ['MASTER_ADDR'] = 'localhost'
    os.environ['MASTER_PORT'] = '12355'
    
   
    dist.init_process_group(backend="nccl", rank=node_rank, world_size=world_size)
    torch.cuda.set_device(node_rank)

def cleanup():
    dist.destroy_process_group()

def train_node(rank, world_size, model_instance, train_loader):
    """
    Core training logic with Mixed Precision (FP16) and DDP synchronization.
    """
    setup_distributed_env(rank, world_size)

   
    model = model_instance.to(rank)
    model = DDP(model, device_ids=[rank])
    
    optimizer = torch.optim.AdamW(model.parameters(), lr=1e-3)
    criterion = nn.CrossEntropyLoss()
    
   
    grad_scaler = GradScaler()

    model.train()
    for batch_idx, (samples, targets) in enumerate(train_loader):
        optimizer.zero_grad(set_to_none=True)
        
       
        with autocast(enabled=True):
            predictions = model(samples.to(rank, non_blocking=True))
            loss = criterion(predictions, targets.to(rank, non_blocking=True))
        
       
        grad_scaler.scale(loss).backward()
        
       
        grad_scaler.step(optimizer)
        grad_scaler.update()

        if rank == 0 and batch_idx % 10 == 0:
            print(f"Node 0 | Batch {batch_idx} | Scale-Optimized Loss: {loss.item():.4f}")

    cleanup()
